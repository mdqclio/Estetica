# ──────────────────────────────────────────────────────────────────────────
# Base de datos (PostgreSQL / Supabase)
# ──────────────────────────────────────────────────────────────────────────
# DATABASE_URL = conexión usada por la APP en runtime.
#   En Supabase usa el POOLER (Transaction) en el puerto 6543 con pgbouncer=true.
#   Ej Supabase: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
#   En local:    postgresql://postgres:postgres@localhost:5432/estetica?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/estetica?schema=public"

# DIRECT_URL = conexión DIRECTA usada por `prisma migrate` (no pasa por el pooler).
#   En Supabase usa el puerto 5432 (conexión directa), sin pgbouncer.
#   Ej Supabase: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
#   En local:    igual que DATABASE_URL.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/estetica?schema=public"

# ──────────────────────────────────────────────────────────────────────────
# Autenticación JWT
# ──────────────────────────────────────────────────────────────────────────
# OBLIGATORIA. Sin valor por defecto: la app no arranca si falta.
# En producción genera una clave aleatoria larga (ej: openssl rand -base64 48).
JWT_SECRET="cambia-esta-clave-super-secreta"
JWT_EXPIRES_IN="1d"

# ──────────────────────────────────────────────────────────────────────────
# Servidor
# ──────────────────────────────────────────────────────────────────────────
# PORT lo asigna Render automáticamente. En local cae a 3001.
PORT=3001

# Origen permitido para CORS (URL del frontend).
#   En local:  http://localhost:5173
#   En prod:   https://<tu-app>.vercel.app
FRONTEND_URL="http://localhost:5173"
