# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/estetica?schema=public"

# Clave secreta para firmar JWT (cámbiala en producción)
JWT_SECRET="cambia-esta-clave-super-secreta"

# Tiempo de expiración del token
JWT_EXPIRES_IN="1d"

# Puerto del backend
PORT=3001

# Origen permitido para CORS (frontend)
FRONTEND_URL="http://localhost:5173"
