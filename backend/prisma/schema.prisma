generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Conexión usada por la app en runtime. En Supabase: pooler (puerto 6543, ?pgbouncer=true).
  url       = env("DATABASE_URL")
  // Conexión directa usada por `prisma migrate`. En Supabase: directa (puerto 5432).
  // En local apunta a la misma base que DATABASE_URL.
  directUrl = env("DIRECT_URL")
}

enum Perfil {
  ADMIN
  RECEPCIONISTA
  PROFISSIONAL
}

model Usuario {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senhaHash String
  perfil    Perfil   @default(RECEPCIONISTA)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("usuarios")
}

model Cliente {
  id             String    @id @default(uuid())
  nome           String
  cpf            String    @unique
  telefone       String?
  email          String?
  dataNascimento DateTime?
  endereco       String?
  observacoes    String?
  ativo          Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("clientes")
}

model Servico {
  id             String   @id @default(uuid())
  nome           String
  descricao      String?
  duracaoMinutos Int
  // Decimal(10,2): estándar para dinero (evita errores de coma flotante).
  // Prisma lo serializa como string en las respuestas JSON.
  preco          Decimal  @db.Decimal(10, 2)
  ativo          Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("servicos")
}
