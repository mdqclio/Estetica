generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Perfil {
  ADMIN
  RECEPCIONISTA
  PROFISSIONAL
}

model Usuario {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senhaHash String
  perfil    Perfil   @default(RECEPCIONISTA)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("usuarios")
}

model Cliente {
  id             String    @id @default(uuid())
  nome           String
  cpf            String    @unique
  telefone       String?
  email          String?
  dataNascimento DateTime?
  endereco       String?
  observacoes    String?
  ativo          Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("clientes")
}
